# LLM Wiki — Ingestion Service Configuration
# Copy this file to .env and fill in your values.

# Required: API key for the LLM provider (OpenAI-compatible)
LLMWIKI_API_KEY=

# API endpoint URL (OpenAI-compatible chat completions API)
# Examples:
#   https://api.opencode.ai/v1       # OpenCode Zen
#   https://api.openai.com/v1        # OpenAI
#   https://api.deepseek.com/v1      # DeepSeek
LLMWIKI_API_ENDPOINT=https://api.opencode.ai/v1

# LLM model to use for classification
LLMWIKI_MODEL=deepseek-v4-flash-free

# ── External directories ──────────────────────────────────────────────
# Base directory for all runtime data (inbox, wiki).
# If empty, the current working directory is used.
# Example: /home/user/llmwiki-data
LLMWIKI_BASE_DIR=

# Inbox and wiki directories — relative to BASE_DIR, or absolute paths.
# If BASE_DIR is /home/user/llmwiki-data, these resolve to:
#   /home/user/llmwiki-data/inbox
#   /home/user/llmwiki-data/wiki
LLMWIKI_INBOX_DIR=inbox
LLMWIKI_WIKI_DIR=wiki

# Watch mode (enable for automatic processing with inotify)
LLMWIKI_WATCH=false

# Enable OCR for images and scanned PDFs (requires Tesseract)
LLMWIKI_OCR_ENABLED=false
